          "docs": "Retrieves all custom tags configured in the Enterprise Hub. Tags are used to add metadata to APIs for filtering and search."
        },
        {
          "info": {
            "name": "Create a tag",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://platform.rapidapi.com/v1/tags",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Creates a new custom tag in the Enterprise Hub for categorizing APIs."
