        {
          "info": {
            "name": "Delete a tag",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://platform.rapidapi.com/v1/tags/:tagId",
            "params": [
              {
                "name": "tagId",
                "value": "",
                "type": "path",
                "description": "The unique identifier of the tag"
              }
            ]
          },
          "docs": "Deletes a custom tag from the Enterprise Hub."
        }
      ]
    },
